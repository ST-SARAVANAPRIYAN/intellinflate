# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Replace with your Atlas connection string
MONGODB_URI=your_mongodb_uri_here
MONGODB_DB=intellinflate_db
JWT_SECRET=your_jwt_secret_here

# ── Server ports ───────────────────────────────────────────────────────────────
HTTP_PORT=3000
WS_PORT=8080

# ── ESP32 Serial (USB cable mode) ─────────────────────────────────────────────
SERIAL_PORT=COM3
BAUD_RATE=115200
